# Database
DATABASE_URL=postgresql+asyncpg://telo:telo_dev@db:5432/telo_venue_assistant
DATABASE_URL_SYNC=postgresql://telo:telo_dev@db:5432/telo_venue_assistant

# Embedding Provider: "openai" or "huggingface"
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# LLM Provider: "openai" or "anthropic"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Retrieval
CHUNK_SIZE=512
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=5
SIMILARITY_THRESHOLD=0.5
RRF_K=60

# App
APP_ENV=development
APP_VERSION=1.0.0
LOG_LEVEL=INFO
